# ── SPC Hub 로그인 (내부망 SSO — 모든 시스템 공통) ───────────────────
SPCHUB_BASE_URL=https://hub.spc.co.kr/ekp/view/login/userLogin
SPCHUB_ID=
SPCHUB_PW=

# ── 내부 시스템 URL (기본값 내장, 변경 불필요) ───────────────────────
OLAP_BASE_URL=https://dwweb.spc.co.kr:7980/SASHBI/main.jsp?board=/01.%20SPC/01.%20OLAP/100.NEW_REPORT
LOG_REPORT_URL=https://hplog.spc.co.kr:8000/datastory/home
VISUAL_REPORT_URL=https://va.spc.co.kr/SASReportViewer/

# ── Google Sheets ────────────────────────────────────────────────────
SHEETS_SPREADSHEET_ID=1gIEbHzyfh4TG21M1etxWxh0u99ylGMsX4B_VGEu3Yxw
SHEETS_CREDENTIALS_PATH=./credentials.json
SHEETS_TOKEN_PATH=./token.json

# ── Gmail 리포트 ─────────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
REPORT_SENDER=
REPORT_RECIPIENTS=

# ── 실패 로그 자동 수집 ──────────────────────────────────────────────
# 실패 시 로그·화면 캡처를 실패 메일에 자동 첨부(항상 동작).
# 추가로 구글 드라이브 공유 폴더에도 업로드하려면 LOG_UPLOAD_DRIVE=1.
#   ※ drive.file 스코프 필요 → 설정 변경 후 token.json 재발급(설치 재실행) 필요.
LOG_UPLOAD_DRIVE=0
# 드라이브 업로드 폴더를 공유할 관리자 이메일 (미설정 시 REPORT_RECIPIENTS 첫 주소).
LOG_ADMIN_EMAIL=

# ── 실행 옵션 ────────────────────────────────────────────────────────
HEADLESS=1       # 0 = 브라우저 화면 표시 (셀렉터 튜닝 시 사용)
DRY_RUN=0        # 1 = Sheets 쓰기·메일 발송 생략 (테스트용)

# ── 경로 ────────────────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
STATE_DIR=./state
LOGS_DIR=./logs

# ── GCP / Pub/Sub (gcp_agent.py 사용 시 필요) ───────────────────────
# 인증: google.auth.default() 자동 탐색 — 키 파일 불필요
#   로컬 PC : gcloud auth application-default login (최초 1회)
#   GCP VM  : VM에 연결된 서비스 계정 자동 사용
GCP_PROJECT_ID=sinuous-athlete-457701-f1
PUBSUB_DAILY_SUBSCRIPTION=ai-rpa-daily-sub
PUBSUB_MONTHLY_SUBSCRIPTION=ai-rpa-monthly-sub
GOOGLE_APPLICATION_CREDENTIALS=./adc.json
